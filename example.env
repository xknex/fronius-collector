# Inverter
FRONIUS_INVERTER_HOST=HOSTNAME_OR_IP
FRONIUS_INVERTER_USE_HTTPS=false
FRONIUS_INVERTER_VERIFY_SSL=false
FRONIUS_INVERTER_DEVICE_ID=1

# Influx
INFLUX_URL=http://HOSTNAME_OR_IP:8086
INFLUX_TOKEN=SECRET
INFLUX_ORG=org
INFLUX_BUCKET=fronius

# Polling/tags
POLLING_INTERVAL=10
TAG_SOURCE=SymoGEN24
TAG_SITE=home

# Extra tags (optional)
TAGS=location=home,env=prod

# --- Aggregation Service (optional) ---
# Hour (local time) to run daily aggregation (default: 0)
# AGGREGATION_SCHEDULE_HOUR=0
# Minute to run daily aggregation (default: 15)
# AGGREGATION_SCHEDULE_MINUTE=15
# Prefix for aggregated measurement names (default: fronius_agg)
# AGGREGATION_MEASUREMENT_PREFIX=fronius_agg
